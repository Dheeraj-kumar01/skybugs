<% layout("layout/boilerplate") %>
<div class="row mt-3">
    <h1 class="col-6 offset-3">Sign Up on wornderluts</h1>
  <div class="col-6 offset-3">
    <form method="post" action="/user/signUp" novalidate class="needs-validation">
        <div class="mt-3">
          <label for="username" class="form-label">username</label>
          <input
            name="username"
            class="form-control"
            placeholder="Enter username"
            required
          />
          <div class="invalid-feedback">
               Please Give Vailed username.
          </div>
          <div class="valid-feedback">
              Looks good!
          </div>
        </div>
        <div >
          <label for="email" class="form-label">Email </label>
          <input
            type="email"
            name="email"
            class="form-control"
            placeholder="Enter email"
            required
          />
          <div class="invalid-feedback">
               Please Give Vailed Email.
          </div>
          <div class="valid-feedback">
              Looks good!
          </div>
        </div>
        <div class="mb-3">
          <label for="password" class="form-label">Password </label>
          <input
            type="password"
            name="password"
            class="form-control"
            placeholder="Enter password"
            required
          />
          <div class="invalid-feedback">
               Give strong Password.
          </div>
          <div class="valid-feedback">
              Looks good!
          </div>
        </div>
        <button type="submit" class="btn btn-success">Sign Up</button>
    </form>
  </div>
</div>
